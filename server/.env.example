# ============================================================
# SpotMe local server config (Groq / Llama edition)
# ------------------------------------------------------------
# 1. Copy this file to `.env`  (cp .env.example .env)
# 2. Paste your Groq API key below, between the quotes
# 3. Never commit the real .env file
#    (.env is already in .gitignore)
#
# Get a free Groq API key at:
#   https://console.groq.com/keys
# (Free tier: 30 req/min, 14,400 req/day, no credit card.)
# ============================================================

# Your Groq API key (starts with gsk_...).
# The server will refuse to start if this is missing or still REPLACE_ME.
GROQ_API_KEY="REPLACE_ME"

# Which Llama model to use for chat (text only).
# llama-3.3-70b-versatile — recommended, best quality
# llama-3.1-8b-instant    — faster, lower quality
GROQ_CHAT_MODEL="llama-3.3-70b-versatile"

# Which Llama Vision model to use for image identification.
# llama-3.2-11b-vision-preview  — smaller, faster
# llama-3.2-90b-vision-preview  — bigger, higher quality (check availability)
GROQ_VISION_MODEL="llama-3.2-11b-vision-preview"

# Port the API server listens on.
PORT=8787

# Comma-separated origins allowed to call this API.
CORS_ORIGINS="http://localhost:8000,http://127.0.0.1:8000,http://localhost:5500,http://127.0.0.1:5500,http://localhost:8787,http://127.0.0.1:8787"

# Any random string. Used to sign session tokens.
SESSION_SECRET="change-me-for-local-dev"
